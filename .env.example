# =============================================================================
# BongTour — 환경 변수 안내 (샘플)
# =============================================================================
# 운영 서버 배포 절차·PM2·nginx: docs/DEPLOY-NAVER-CLOUD.md — 프로덕션 템플릿: `.env.production.example` (실제 파일 `.env.production`은 Git 제외)
# 문의 접수 관리자 메일(SMTP): docs/OPS-INQUIRY-SMTP.md
# `npm run build` 시 package.json prebuild 로 prisma generate 가 자동 실행됩니다.
# 이 파일은 저장소에 커밋되는 참고용입니다. 실제 값은 넣지 마세요.
# 로컬 실행: 프로젝트 루트에 `.env.local` 을 만들고 필요한 키만 복사해 채웁니다.
# Next.js는 `.env`, `.env.local` 순으로 로드합니다(`.env.local` 우선).
#
# 운영(production + Node): instrumentation → lib/server-env.ts assertProductionServerEnv 가
# AUTH_SECRET|NEXTAUTH_SECRET, NEXTAUTH_URL, NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_APP_URL,
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY 누락 시 기동 실패 — 상세는 `.env.production.example`.
#
# [서버 전용] 브라우저에 노출되면 안 되는 키 — NEXT_PUBLIC_ 접두어 없음
# [클라이언트] NEXT_PUBLIC_* 만 빌드에 포함되어 브라우저에서 읽힐 수 있음
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Prisma) — SQLite
# -----------------------------------------------------------------------------
# prisma/schema.prisma 의 datasource provider 는 sqlite 입니다.
# DATABASE_URL="file:./dev.db" → 실제 파일은 prisma/dev.db (스키마 파일이 있는 prisma/ 폴더 기준).
# prisma/prisma/dev.db 등 중첩 경로는 사용하지 않습니다(레거시 복제 제거).
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Auth.js / NextAuth — 세션·JWT 서명
# -----------------------------------------------------------------------------
# 운영(production): 배포 환경에 강한 비밀값 필수. 생성 예: openssl rand -base64 32
# 로컬: `.env.local` 에만 넣어도 됨. 저장소 `.env` 에는 약한 플레이스홀더가 있을 수 있음(팀 템플릿용).
# AUTH_SECRET 이 없으면 NEXTAUTH_SECRET 을 읽습니다(호환).
AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# 관리자 parse-and-register: 미리보기 없이 confirm 저장 방지용 HMAC 비밀.
# 로컬(development): 미설정 시 AUTH_SECRET 또는 개발 전용 fallback 허용.
# 운영(production): REGISTRATION_PREVIEW_SECRET 또는(개발 플레이스홀더가 아닌) AUTH_SECRET 필수 — 미설정 시 confirm 토큰 발급/검증 실패.
# REGISTRATION_PREVIEW_SECRET=""
# 절대 URL이 필요할 때(예: 관리자 이미지 URL, instrumentation 안내)
# 로컬 dev: `npm run dev` 는 `next dev -p 3000` 고정. 3000이 이미 쓰이면 해당 프로세스를 종료한 뒤 다시 띄우세요(다른 포트로 자동 전환하지 않음).
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Kakao 로그인 (선택 — KAKAO_CLIENT_ID + SECRET 없으면 로그인 화면에서 버튼 미표시)
# -----------------------------------------------------------------------------
# 흐름: GET /api/auth/kakao → kauth.kakao.com 승인 → GET /api/auth/kakao/callback (토큰·프로필·DB·세션)
#
# [콘솔 등록] 「카카오 로그인 → Redirect URI」와 「비즈니스 인증 → 리다이렉트 URI」에 **동일** URL 등록.
#   로컬: http://localhost:3000/api/auth/kakao/callback
#   운영: https://bongtour.com/api/auth/kakao/callback
#   (www 로만 들어오면 https://www.bongtour.com/api/auth/kakao/callback 도 콘솔에 추가)
# [플랫폼] Web 사이트 도메인: 로컬은 http://localhost:3000 , 운영은 https://bongtour.com
#
# [env] KAKAO_CLIENT_ID = REST API 키
#       KAKAO_CLIENT_SECRET = **제품 설정 → 카카오 로그인 → Client Secret** (토큰 발급에 사용)
#       → 비즈니스 인증 전용 시크릿이 아님. 이 앱은 lib/kakao-oauth-public.ts + callback/route.ts 에서 위 Secret 만 사용.
#
# [권장 순서] 로컬 .env.local + localhost Redirect 로 동작 확인 → 콘솔에 운영 URI 추가 → 서버 .env.production 에 동일 키·운영 URL
# [운영 권장] redirect_uri 고정: KAKAO_CALLBACK_URL=https://bongtour.com/api/auth/kakao/callback
# KAKAO_CALLBACK_URL 비우면 {공개 origin}/api/auth/kakao/callback (lib/kakao-oauth-public.ts)
# KAKAO_OAUTH_PUBLIC_ORIGIN / KAKAO_OAUTH_DEBUG / KAKAO_OAUTH_COOKIE_DOMAIN (선택, 네이버 OAuth와 동일 취지)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
# KAKAO_CALLBACK_URL=""
# KAKAO_OAUTH_PUBLIC_ORIGIN=""
# KAKAO_OAUTH_DEBUG=""
# KAKAO_OAUTH_COOKIE_DOMAIN=""

# -----------------------------------------------------------------------------
# 네이버 로그인 — OAuth2 authorization code (공식 문서의 implicit JS 예제는 사용하지 않음)
# 흐름: GET /api/auth/naver → nid.naver.com 승인 → GET /api/auth/naver/callback (토큰·프로필·DB·세션)
# -----------------------------------------------------------------------------
# 개발자센터 > 내 애플리케이션 > API 설정 — Callback URL 은 authorize 에 넣는 redirect_uri 와 동일해야 함.
# 미설정 시: {공개 origin}/api/auth/naver/callback (공개 origin 은 lib/naver-oauth-public.ts 참고).
# NAVER_CALLBACK_URL 을 비우면 NEXTAUTH_URL 등으로 redirect_uri 가 자동 계산됨(운영·로컬 혼선 방지).
# (선택) OAuth 공개 URL 강제: NAVER_OAUTH_PUBLIC_ORIGIN=https://bongtour.com — 프록시 뒤에서 Host 추론이 어긋날 때
# (선택) 디버그 로그: NAVER_OAUTH_DEBUG=1 (운영에서만 잠깐 켤 것)
# 개발자센터 > API 권한관리 — 「네이버 로그인」 권한이 켜져 있어야 함(없으면 403).
# 운영 예 redirect: https://bongtour.com/api/auth/naver/callback
# 로컬 예 redirect: http://localhost:3000/api/auth/naver/callback
# 연결 끊기 Callback(네이버 콘솔): https://bongtour.com/Api/Member/Oauth20 — app/Api/Member/Oauth20/route.ts (별도 env 없음, 동일 CLIENT_ID/SECRET)
# (선택) www·apex 혼용 시 state 쿠키 공유: NAVER_OAUTH_COOKIE_DOMAIN=.bongtour.com
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_CALLBACK_URL=""
# NAVER_OAUTH_PUBLIC_ORIGIN=""
# NAVER_OAUTH_DEBUG=""
# NAVER_OAUTH_COOKIE_DOMAIN=""

# -----------------------------------------------------------------------------
# 역할·관리자 (선택)
# -----------------------------------------------------------------------------
# 해당 이메일로 가입/로그인 시 관리자 롤 부여 등에 사용 (lib/bootstrap-user-role.ts)
ADMIN_EMAIL=""
# 최고관리자 이메일 목록(쉼표 구분)
SUPER_ADMIN_EMAIL=""

# -----------------------------------------------------------------------------
# npm run admin:bootstrap (스크립트 전용, 선택)
# 미설정 시 scripts/bootstrap-admin.ts 기본값 사용. 비밀번호는 Git에 넣지 말고 서버 .env 에만 두세요.
# ADMIN_BOOTSTRAP_EMAIL=""
# ADMIN_BOOTSTRAP_NAME=""
# ADMIN_BOOTSTRAP_PASSWORD=""

# -----------------------------------------------------------------------------
# 개발 전용 — 관리자 우회·모의 세션 (운영·VERCEL_ENV=production 에서는 절대 동작하지 않음)
# -----------------------------------------------------------------------------
# 아래를 모두 만족할 때만 바이패스·mock 경로가 열림: NODE_ENV=development, VERCEL_ENV≠production,
# BONGTOUR_DEV_ADMIN_BYPASS=true, (우회 시) DEV_ADMIN_BYPASS_SECRET(권장) 또는 구 ADMIN_BYPASS_SECRET 일치.
BONGTOUR_DEV_ADMIN_BYPASS="false"
# 로컬 /admin?auth= 쿼리 · admin_bypass 쿠키 — 운영 Bearer 키와 분리 권장
DEV_ADMIN_BYPASS_SECRET=""
# Python 스케줄러 등 Authorization: Bearer — 서비스 간 전용
ADMIN_SERVICE_BEARER_SECRET=""
# 레거시 단일 키(새 키 미설정 시 개발 쿠키·Bearer 폴백)
ADMIN_BYPASS_SECRET=""
# layout/getAdminSession·requireAdmin mock — BONGTOUR_DEV_ADMIN_BYPASS=true 일 때만 유효
ALLOW_MOCK_ADMIN="false"

# -----------------------------------------------------------------------------
# Rate limit (선택) — Node API 라우트에서 Redis. Edge 미들웨어는 메모리 고정.
# -----------------------------------------------------------------------------
# REDIS_URL=""
# BONGTOUR_REDIS_URL=""

# -----------------------------------------------------------------------------
# 공개 URL / 클라이언트 (NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# 사이트 기준 URL(링크 생성, 서버 fetch 기준 origin 보조). 미설정 시 일부 기본값 사용
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# 예약 관리 링크 등에 사용 (app/api/bookings 등)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# 카카오 상담 진입 URL. 미설정 시 코드 기본값(채널 친구 URL) — lib/kakao-open-chat.ts 의 KAKAO_OPEN_CHAT_URL_FALLBACK
# `npm run verify:inquiry:live` 운영 검수에서는 **기본값과 동일한 env 는 거부**되며, 실제 오픈채팅/채널 URL을 넣어야 함.
NEXT_PUBLIC_KAKAO_OPEN_CHAT_URL="https://pf.kakao.com/_xlxjrxlX/friend"
# Google Maps 임베드(상세 여행지). 없으면 외부 링크만 표시
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=""
# Google Tag Manager 컨테이너 ID. 없으면 GTM 스크립트 미로드
NEXT_PUBLIC_GTM_ID=""
# 헤더에서 로고와 같은 줄·반대편(GNB 오른쪽) 인스타그램 아이콘 링크. 비우면 미표시
# 공개 프로필(추적 쿼리 없이): https://www.instagram.com/bongtour103
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/bongtour103"

# -----------------------------------------------------------------------------
# 문의 접수 — 관리자 알림 메일 (SMTP, lib/inquiry-email.ts + POST /api/inquiries)
# -----------------------------------------------------------------------------
# [필수] 아래가 모두 채워져야 발송. 하나라도 비면 send 시 Error → API는 DB 저장 유지 후 notification 실패 처리.
# SMTP_USER / SMTP_PASS = SMTP 인증. From 은 SMTP_FROM_* 만 사용(고객 이메일은 Reply-To).
# 수신(To)=INQUIRY_NOTIFICATION_EMAIL.
# `npm run verify:inquiry:live` 운영 검수에서는 example.com / ethereal 불가.
#
# 운영 최종 검수(이메일+카카오 URL 일치·DB·자동 단계): npm run verify:inquiry:live
# 구조/회귀만(Ethereal 등): npx tsx scripts/local-verify-inquiry-live.ts --sandbox
#
# 예시(네이버: smtp.naver.com, 587 + STARTTLS 가 일반적):
# SMTP_HOST="smtp.naver.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="발송용@naver.com"
# SMTP_PASS="앱비밀번호"
# SMTP_FROM_NAME="봉투어"
# SMTP_FROM_EMAIL="발송용@naver.com"
# INQUIRY_NOTIFICATION_EMAIL="관리자수신@example.com"
#
# 로컬에서 발송 경로만 검증: npm run test:inquiry-smtp -- --ethereal
# 실제 계정으로 검증: .env.local 채운 뒤 npm run test:inquiry-smtp
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME=""
SMTP_FROM_EMAIL=""
INQUIRY_NOTIFICATION_EMAIL=""

# 예약 요청 접수 — 관리자 메일 수신 (lib/booking-email.ts). 비우면 INQUIRY_NOTIFICATION_EMAIL로 폴백.
BOOKING_NOTIFICATION_EMAIL=""
# 예약 관리자 메일 본문에 internal productId·raw JSON 등 디버그 블록 포함 (기본 비활성)
BOOKING_ADMIN_EMAIL_DEBUG=""

# -----------------------------------------------------------------------------
# Solapi (SMS/알림톡) — 통일된 env 이름
# -----------------------------------------------------------------------------
# [문의] lib/solapi-alimtalk.ts 알림톡 + lib/notification-service.ts 관리자 LMS·고객 LMS 폴백
# [예약] 관리자 SMS — SOLAPI_API_KEY, SOLAPI_API_SECRET, SOLAPI_FROM_PHONE, ADMIN_PHONE
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_FROM_PHONE=""
# 문의 관리자 수신(복수: 쉼표 구분 예 01012345678,01087654321)
SOLAPI_ADMIN_PHONES=""
# 카카오 채널 PF ID (알림톡)
SOLAPI_PFID=""
# 알림톡 템플릿 ID(솔라피 콘솔 등록값)
SOLAPI_TPL_BUS=""
SOLAPI_TPL_TRAINING=""
SOLAPI_TPL_INSTITUTION=""
SOLAPI_TPL_PRIVATE_QUOTE=""
SOLAPI_TPL_TRAVEL_CONSULT=""
ADMIN_PHONE=""

