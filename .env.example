# =============================================================================
# BongTour — 환경 변수 안내 (샘플)
# =============================================================================
# 운영 서버 배포 절차·PM2·nginx: docs/DEPLOY-NAVER-CLOUD.md — 프로덕션 템플릿: `.env.production.example` (실제 파일 `.env.production`은 Git 제외)
# 문의 접수 관리자 메일(SMTP): docs/OPS-INQUIRY-SMTP.md
# `npm run build` 시 package.json prebuild 로 prisma generate 가 자동 실행됩니다.
# 이 파일은 저장소에 커밋되는 참고용입니다. 실제 값은 넣지 마세요.
# 로컬 실행: 프로젝트 루트에 `.env.local` 을 만들고 필요한 키만 복사해 채웁니다.
# Next.js는 `.env`, `.env.local` 순으로 로드합니다(`.env.local` 우선).
#
# 운영(production + Node): instrumentation → lib/server-env.ts assertProductionServerEnv 가
# AUTH_SECRET|NEXTAUTH_SECRET, NEXTAUTH_URL, NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_APP_URL,
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY 누락 시 기동 실패 — 상세는 `.env.production.example`.
#
# [서버 전용] 브라우저에 노출되면 안 되는 키 — NEXT_PUBLIC_ 접두어 없음
# [클라이언트] NEXT_PUBLIC_* 만 빌드에 포함되어 브라우저에서 읽힐 수 있음
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Prisma) — SQLite
# -----------------------------------------------------------------------------
# prisma/schema.prisma 의 datasource provider 는 sqlite 입니다.
# DATABASE_URL="file:./dev.db" → 실제 파일은 prisma/dev.db (스키마 파일이 있는 prisma/ 폴더 기준).
# prisma/prisma/dev.db 등 중첩 경로는 사용하지 않습니다(레거시 복제 제거).
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Auth.js / NextAuth — 세션·JWT 서명
# -----------------------------------------------------------------------------
# 운영(production): 배포 환경에 강한 비밀값 필수. 생성 예: openssl rand -base64 32
# 로컬: `.env.local` 에만 넣어도 됨. 저장소 `.env` 에는 약한 플레이스홀더가 있을 수 있음(팀 템플릿용).
# AUTH_SECRET 이 없으면 NEXTAUTH_SECRET 을 읽습니다(호환).
AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# 관리자 parse-and-register: 미리보기 없이 confirm 저장 방지용 HMAC 비밀.
# 로컬(development): 미설정 시 AUTH_SECRET 또는 개발 전용 fallback 허용.
# 운영(production): REGISTRATION_PREVIEW_SECRET 또는(개발 플레이스홀더가 아닌) AUTH_SECRET 필수 — 미설정 시 confirm 토큰 발급/검증 실패.
# REGISTRATION_PREVIEW_SECRET=""
# 절대 URL이 필요할 때(예: 관리자 이미지 URL, instrumentation 안내)
# 로컬 dev: `npm run dev` 는 `next dev -p 3000` 고정. 3000이 이미 쓰이면 해당 프로세스를 종료한 뒤 다시 띄우세요(다른 포트로 자동 전환하지 않음).
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Kakao 로그인 (선택 — 미설정 시 카카오 프로바이더 비활성)
# -----------------------------------------------------------------------------
# https://developers.kakao.com 앱 키
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# 네이버 로그인 — 수동 OAuth (GET /api/auth/naver → 네이버 → GET /api/auth/naver/callback)
# -----------------------------------------------------------------------------
# 네이버 개발자센터에 등록하는 Callback URL 과 NAVER_CALLBACK_URL 값이 반드시 같아야 함(스킴·호스트·경로·www 유무).
# 이 프로젝트는 Auth.js 기본 경로(/api/auth/callback/naver)를 쓰지 않음.
# 운영 예: https://bongtour.com/api/auth/naver/callback
# 로컬 예: http://localhost:3000/api/auth/naver/callback
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_CALLBACK_URL=""

# -----------------------------------------------------------------------------
# 역할·관리자 (선택)
# -----------------------------------------------------------------------------
# 해당 이메일로 가입/로그인 시 관리자 롤 부여 등에 사용 (lib/bootstrap-user-role.ts)
ADMIN_EMAIL=""
# 최고관리자 이메일 목록(쉼표 구분)
SUPER_ADMIN_EMAIL=""

# -----------------------------------------------------------------------------
# npm run admin:bootstrap (스크립트 전용, 선택)
# 미설정 시 scripts/bootstrap-admin.ts 기본값 사용. 비밀번호는 Git에 넣지 말고 서버 .env 에만 두세요.
# ADMIN_BOOTSTRAP_EMAIL=""
# ADMIN_BOOTSTRAP_NAME=""
# ADMIN_BOOTSTRAP_PASSWORD=""

# -----------------------------------------------------------------------------
# 개발 전용 — 관리자 우회·모의 세션 (운영·VERCEL_ENV=production 에서는 절대 동작하지 않음)
# -----------------------------------------------------------------------------
# 아래를 모두 만족할 때만 바이패스·mock 경로가 열림: NODE_ENV=development, VERCEL_ENV≠production,
# BONGTOUR_DEV_ADMIN_BYPASS=true, (우회 시) DEV_ADMIN_BYPASS_SECRET(권장) 또는 구 ADMIN_BYPASS_SECRET 일치.
BONGTOUR_DEV_ADMIN_BYPASS="false"
# 로컬 /admin?auth= 쿼리 · admin_bypass 쿠키 — 운영 Bearer 키와 분리 권장
DEV_ADMIN_BYPASS_SECRET=""
# Python 스케줄러 등 Authorization: Bearer — 서비스 간 전용
ADMIN_SERVICE_BEARER_SECRET=""
# 레거시 단일 키(새 키 미설정 시 개발 쿠키·Bearer 폴백)
ADMIN_BYPASS_SECRET=""
# layout/getAdminSession·requireAdmin mock — BONGTOUR_DEV_ADMIN_BYPASS=true 일 때만 유효
ALLOW_MOCK_ADMIN="false"

# -----------------------------------------------------------------------------
# Rate limit (선택) — Node API 라우트에서 Redis. Edge 미들웨어는 메모리 고정.
# -----------------------------------------------------------------------------
# REDIS_URL=""
# BONGTOUR_REDIS_URL=""

# -----------------------------------------------------------------------------
# 공개 URL / 클라이언트 (NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# 사이트 기준 URL(링크 생성, 서버 fetch 기준 origin 보조). 미설정 시 일부 기본값 사용
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# 예약 관리 링크 등에 사용 (app/api/bookings 등)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# 카카오 상담 진입 URL. 미설정 시 코드 기본값(채널 친구 URL) — lib/kakao-open-chat.ts 의 KAKAO_OPEN_CHAT_URL_FALLBACK
# `npm run verify:inquiry:live` 운영 검수에서는 **기본값과 동일한 env 는 거부**되며, 실제 오픈채팅/채널 URL을 넣어야 함.
NEXT_PUBLIC_KAKAO_OPEN_CHAT_URL="https://pf.kakao.com/_xlxjrxlX/friend"
# 네이버 톡톡 상담 진입 URL — 반드시 파트너센터 > 해당 프로필 > 실제 대화 진입 URL과 동일한 경로(예: https://talk.naver.com/w2r7vau ). 다른 ID면 "사용 중지"·다른 상대처럼 보일 수 있음. 미설정 시 톡톡 버튼 비활성.
# 운영 검수 스크립트는 비어 있으면 실패(talk.naver.com + 비어 있지 않은 path 필수).
NEXT_PUBLIC_NAVER_TALKTALK_URL=""
# 파트너센터 배너 소스의 data-id (예: 173064). 비우면 푸터에 공식 배너 스크립트 미삽입.
NEXT_PUBLIC_NAVER_TALKTALK_BANNER_ID=""
# Google Maps 임베드(상세 여행지). 없으면 외부 링크만 표시
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=""
# Google Tag Manager 컨테이너 ID. 없으면 GTM 스크립트 미로드
NEXT_PUBLIC_GTM_ID=""
# 헤더에서 로고와 같은 줄·반대편(GNB 오른쪽) 인스타그램 아이콘 링크. 비우면 미표시
# 공개 프로필(추적 쿼리 없이): https://www.instagram.com/bongtour103
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/bongtour103"

# -----------------------------------------------------------------------------
# 문의 접수 — 관리자 알림 메일 (SMTP, lib/inquiry-email.ts + POST /api/inquiries)
# -----------------------------------------------------------------------------
# [운영 권장] 다섯 값이 모두 있어야 발송됨. 하나라도 비면 send 시 Error → API는 DB 저장 유지 후 notification 실패 처리.
# [필수] SMTP_HOST, SMTP_USER, SMTP_PASS — 연결·인증
# [필수] 발신 주소 — INQUIRY_MAIL_FROM 이 비어 있으면 SMTP_USER 가 발신(From)으로 사용됨(여전히 값이 있어야 함)
# [선택] SMTP_PORT — 비우면 SMTP_SECURE=true 이면 465, 아니면 587 (숫자 문자열, 예: "587", "465")
# [선택] SMTP_SECURE — "true" 이면 TLS 직결(일반적으로 465). false/미설정 이면 STARTTLS(일반적으로 587)
# [선택] INQUIRY_RECEIVER_EMAIL — 관리자 수신함. 비우면 코드 기본 bongtour24@naver.com (앱 동작).
# `npm run verify:inquiry:live` 운영 검수에서는 **반드시 명시**해야 하며 example.com / ethereal 불가.
#
# 운영 최종 검수(이메일+카카오+톡톡 URL 일치·DB·자동 단계): npm run verify:inquiry:live
# 구조/회귀만(Ethereal 등): npx tsx scripts/local-verify-inquiry-live.ts --sandbox
#
# 예시(네이버/구글 등은 각 SMTP 안내에 맞게 호스트·포트 조정):
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="noreply@example.com"
# SMTP_PASS="앱비밀번호또는SMTP비밀번호"
# INQUIRY_MAIL_FROM="BongTour <noreply@example.com>"
# INQUIRY_RECEIVER_EMAIL="ops@example.com"
#
# 로컬에서 발송 경로만 검증: npm run test:inquiry-smtp -- --ethereal
# 실제 계정으로 검증: .env.local 채운 뒤 npm run test:inquiry-smtp
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
INQUIRY_MAIL_FROM=""
INQUIRY_RECEIVER_EMAIL=""

# -----------------------------------------------------------------------------
# Solapi (SMS/알림) — 코드마다 키 이름이 다릅니다. 사용하는 기능에 맞게 설정
# -----------------------------------------------------------------------------
# [예약 알림] lib/notification-service.ts — 관리자 문자(Solapi)
# 문의 접수(POST /api/inquiries) 운영자 자동 알림은 이메일만 사용 — Solapi는 예약 경로용
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
ADMIN_PHONE=""
SENDER_PHONE=""
#
# [알림톡 등] lib/solapi-alimtalk.ts
SOLAPI_KEY=""
SOLAPI_SECRET=""
SOLAPI_SENDER=""

# -----------------------------------------------------------------------------
# Google Gemini / Imagen (AI 추출·이미지 생성)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""
# Google AI Studio 등에서 쓰는 이름. GEMINI_API_KEY가 없을 때만 사용(lib/gemini-client.ts)
GOOGLE_API_KEY=""
# 미설정 시 gemini-2.5-flash. gemini-3-flash-preview 등은 키/프로그램에 따라 403 가능
GEMINI_MODEL=""
# 선택: 연결 테스트(Hello World)·본문 추출 타임아웃(ms). 미설정 시 25000 / 115000
# GEMINI_CONNECT_TIMEOUT_MS=""
# GEMINI_GENERATE_TIMEOUT_MS=""
# 등록 확정 풀 JSON 출력 상한(기본 65536). 긴 일정·호텔 배열에서 MAX_TOKENS 잘림 시 조정.
# GEMINI_REGISTER_FULL_MAX_OUTPUT_TOKENS=""
# 선택. 기본 v1
# GEMINI_API_VERSION="v1"
# 관리자 Imagen — IMAGEN_MODEL 우선, 없으면 GEMINI_IMAGEN_MODEL
IMAGEN_MODEL=""
# GEMINI_IMAGEN_MODEL=""

# -----------------------------------------------------------------------------
# Supabase — Postgres(travel_reviews 등) + Storage(관리자 이미지·제미나이·사진풀)
# 서버 전용: SUPABASE_SERVICE_ROLE_KEY 는 클라이언트/번들에 넣지 않는다.
# Storage 버킷은 대시보드에서 공개 읽기로 만들거나, 로컬에서
# `npm run bootstrap:supabase-storage` 로 공개 버킷 생성 + 경로별 .keep 시드 가능.
# -----------------------------------------------------------------------------
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Supabase 대시보드 → Project Settings → API 의 **anon public** 키(서버 env만 써도 됨). 우리여행 히어로 직접 업로드 경로에 사용.
# SUPABASE_ANON_KEY=""
# 이미지 업로드 버킷 (기본 bongtour-images)
# SUPABASE_IMAGE_BUCKET="bongtour-images"
# (선택) 클라이언트 번들에 넣을 때만 — 없으면 서버의 SUPABASE_URL / SUPABASE_ANON_KEY 로 동일 동작 가능
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

