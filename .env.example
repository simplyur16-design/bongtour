# -----------------------------------------------------------------------------
# 예약 PII 익명화 배치 (scripts/purge-old-bookings.ts)
# -----------------------------------------------------------------------------
# BOOKING_PII_RETENTION_DAYS="365"
# BOOKING_PII_PURGE_ALERT_WEBHOOK_URL=""
# BOOKING_PII_PURGE_NOTIFY_DRY_RUN=""
