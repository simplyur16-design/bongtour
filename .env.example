BONGSIM_MOCK_WEBHOOK_SECRET=
BONGSIM_ORDER_READ_KEY=
BONGSIM_SUPPLIER_CLIENT_ID=usimsa

# 웰컴페이먼츠(PayWelcome) — 봉심 eSIM 카드결제 (`provider: welcomepay`). 실제 키는 `.env.local` 등에만 저장.
# PayWelcome 빌링 테스트 MID 예: `wpaybill01`. signKey는 가맹 대시보드 발급값(구 예시 `welcometst` 등은 사용하지 않음).
WELCOMEPAY_MID=
WELCOMEPAY_SIGN_KEY=
WELCOMEPAY_ENV=test
# (선택) PAYAPI 전체취소 hash용 clientIp — 미설정 시 0.0.0.0
# WELCOMEPAY_CANCEL_CLIENT_IP=

# === USIMSA 웹훅 IP 화이트리스트 ===
USIMSA_WEBHOOK_ALLOWED_IPS=

# === PostgreSQL SSL ===
BONGSIM_PG_SSL_STRICT=

