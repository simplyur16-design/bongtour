# -----------------------------------------------------------------------------
# 로컬에서 네이버·카카오 로그인만 켜볼 때
# -----------------------------------------------------------------------------
# 네이버 로그인 OAuth(Client ID/Secret, NAVER_CALLBACK_URL)와 NEXTAUTH_URL 등은
# 전부 프로젝트 루트 `.env.local` 에만 두면 됨(Git 제외). `npm run dev` 가 자동 로드.
# 1) 이 파일을 복사해 프로젝트 루트에 `.env.local` 로 저장 (Git에 안 올라감)
# 2) 아래 빈 칸에 카카오/네이버 개발자 콘솔에서 발급한 값만 채움
# 3) 콘솔에 아래 URL을 Redirect / Callback 으로 **그대로** 등록
# 4) `npm run dev` → http://localhost:3000/auth/signin (포트 3000 고정)
# -----------------------------------------------------------------------------

NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# (권장) 로컬에서도 고정 문자열 권장. 예: openssl rand -base64 32
AUTH_SECRET=

# --- 카카오 (로컬 먼저 → 운영) ---
# 1) 카카오 디벨로퍼스 — 플랫폼 > Web > 사이트 도메인: http://localhost:3000
# 2) 같은 콘솔 — 「카카오 로그인 Redirect URI」+「비즈니스 인증 리다이렉트 URI」에 **똑같이**:
#      http://localhost:3000/api/auth/kakao/callback
# 3) 아래 KAKAO_CLIENT_ID = REST API 키 / KAKAO_CLIENT_SECRET = **카카오 로그인** Client Secret (비즈니스 인증 전용 Secret 아님)
# 4) npm run dev → /auth/signin 에서 카카오 로그인 성공 확인
# 5) 운영 반영 시: 콘솔에 https://bongtour.com/api/auth/kakao/callback (및 필요 시 www) 추가,
#    서버 .env.production 에 KAKAO_* 복사 + 권장 KAKAO_CALLBACK_URL=https://bongtour.com/api/auth/kakao/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- 네이버 ---
# 네이버 개발자센터 > Application > API 설정 > Callback URL 과 **한 글자까지 동일**
# NAVER_CALLBACK_URL=http://localhost:3000/api/auth/naver/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:3000/api/auth/naver/callback
