# BongTour — nginx site example (copy, fix paths/certs, link from sites-enabled)
# CSP / session / Naver OAuth: browser origin must match NEXTAUTH_URL and NEXT_PUBLIC_*.
# If canonical is https://bongtour.com: redirect www → 301; keep env on same host.

upstream bongtour_node {
    server 127.0.0.1:3000;
    keepalive 64;
}

# www → non-www (delete this server block if not needed)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.bongtour.com;

    ssl_certificate     /etc/letsencrypt/live/bongtour.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bongtour.com/privkey.pem;

    return 301 https://bongtour.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name bongtour.com;

    ssl_certificate     /etc/letsencrypt/live/bongtour.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bongtour.com/privkey.pem;

    client_max_body_size 25m;

    location / {
        proxy_pass         http://bongtour_node;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        # Long requests: admin product register (LLM), departures rescrape, etc.
        # Default proxy_read_timeout (~60s) often returns 502 before the app responds.
        proxy_connect_timeout 60s;
        proxy_send_timeout     960s;
        proxy_read_timeout     960s;
    }
}

# HTTP → HTTPS (keep one block if certbot already added one)
