# 프로덕션 환경 변수 템플릿 — 서버에서 `.env.production`으로 복사 후 값 입력
# 실제 비밀이 들어간 `.env.production`은 Git에 커밋하지 마세요 (.gitignore).

NODE_ENV=production
PORT=3000

DATABASE_URL="file:/var/www/bongtour/prisma/prod.db"

AUTH_SECRET=""
# 호환: 미설정 시 NEXTAUTH_SECRET 도 읽힘(assertProductionServerEnv 동일 검사)
# NEXTAUTH_SECRET=""
# nginx 프록시 뒤 배포 시 세션·미들웨어 호스트 불일치 방지(미설정 시 운영에서 /admin 로그인 루프 가능)
# AUTH_TRUST_HOST=true
NEXTAUTH_URL="https://your-domain.example.com"

NEXT_PUBLIC_SITE_URL="https://your-domain.example.com"
NEXT_PUBLIC_APP_URL="https://your-domain.example.com"
# 선택: 서버 런타임 전용(빌드 없이 .env 만 바꿀 때 기동 검증·일부 서버 코드용). 비우면 NEXT_PUBLIC_* 와 동일 값 권장.
# SITE_URL="https://your-domain.example.com"
# APP_URL="https://your-domain.example.com"

# 헤더 인스타그램 아이콘 링크(공개 URL). 비우면 미표시
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/bongtour103"

BONGTOUR_API_BASE="https://your-domain.example.com"

# -----------------------------------------------------------------------------
# 문의 접수 — 관리자 알림 메일 (SMTP). 상세·체크리스트: docs/OPS-INQUIRY-SMTP.md
# lib/inquiry-email.ts — 필수: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM_NAME, SMTP_FROM_EMAIL, INQUIRY_NOTIFICATION_EMAIL
# -----------------------------------------------------------------------------
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM_NAME="봉투어"
# SMTP_FROM_EMAIL=""
# INQUIRY_NOTIFICATION_EMAIL=""

# 네이버 로그인 — NAVER_CALLBACK_URL 은 네이버 개발자센터 Callback URL 과 동일해야 함
# NAVER_CLIENT_ID=""
# NAVER_CLIENT_SECRET=""
# NAVER_CALLBACK_URL="https://your-domain.example.com/api/auth/naver/callback"

# assertProductionServerEnv (instrumentation.ts) — production + nodejs 런타임 기동 시 필수
# AUTH_SECRET 또는 NEXTAUTH_SECRET, NEXTAUTH_URL, 공개 URL(SITE_URL / NEXT_PUBLIC_SITE_URL / APP_URL / NEXT_PUBLIC_APP_URL 중 택일),
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY (GEMINI_API_KEY/GOOGLE_API_KEY는 없어도 기동 가능, 경고만)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
GEMINI_API_KEY=""

# 스케줄러 등 Authorization: Bearer (/api/admin/*). DEV_ADMIN_BYPASS_SECRET·BONGTOUR_DEV_ADMIN_BYPASS 는 운영에서 미사용
ADMIN_SERVICE_BEARER_SECRET=""
# 레거시: 새 키 미설정 시 lib/admin-secrets.ts 가 Bearer·개발 쿠키 폴백으로 읽음 — 분리 전환 권장
# ADMIN_BYPASS_SECRET=""
# 선택: Node 라우트 rate limit 공유(Edge 미들웨어는 메모리 고정)
# REDIS_URL=""
# BONGTOUR_REDIS_URL=""
# 기동 후 확인: npm run verify:rate-limit-store (Node에서만 실행, 표시되는 kind는 미들웨어와 별개)

# ybtour 관리자 출발일/가격 재수집(E2E): venv 에 playwright+chromium 설치 후 절대 경로 권장 (미설정 시 linux 에서 python3 사용)
# PYTHON="/var/www/bongtour/.venv/bin/python"
# PM2 cwd 가 레포 루트가 아니면 PYTHONPATH 대신 이 경로로 스크립트 루트 지정
# BONGTOUR_REPO_ROOT="/var/www/bongtour"

