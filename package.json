{
  "name": "bongtour",
  "version": "0.1.0",
  "private": true,
  "description": "BongTour — 로컬 dev는 http://localhost:3000 고정 (`next dev -p 3000`). 권장 복구: npm run dev:clean (scripts/README-dev.md, docs/DEV-NEXT-CACHE.md). package.json overrides로 react/react-dom 18.2.0 고정 후에는 node_modules 삭제 후 재설치 권장: PowerShell `Remove-Item -Recurse -Force node_modules; npm install` / Unix `rm -rf node_modules && npm install`.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "npm run check:register-supplier-imports && prisma generate",
    "dev": "next dev -p 3000",
    "clean:next": "node scripts/clean-next.js",
    "dev:clean": "npm run clean:next && next dev -p 3000",
    "build:clean": "npm run clean:next && npm run build",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "check:register-supplier-imports": "node scripts/check-register-supplier-cross-imports.mjs",
    "check": "npm run check:register-supplier-imports && npm run lint",
    "get-bg-color": "node scripts/get-envelope-bg-color.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:safe": "node scripts/prisma-generate-safe.js",
    "admin:bootstrap": "npx tsx scripts/bootstrap-admin.ts",
    "migrate:prisma-images-ncloud": "npx tsx scripts/migrate-prisma-images-to-ncloud.ts",
    "migrate:pexels": "npx tsx scripts/migrate-pexels-to-ncloud.ts",
    "test:inquiry-smtp": "npx tsx scripts/test-inquiry-smtp.ts",
    "test:inquiry-smtp:587": "npx tsx scripts/test-inquiry-smtp.ts --try-587",
    "verify:inquiry:live": "npx tsx scripts/local-verify-inquiry-live.ts",
    "e2e:inquiry-three-api": "npx tsx scripts/e2e-inquiry-three-api.ts",
    "db:push": "prisma db push",
    "db:sqlite:ensure-product-bgimage": "node scripts/sqlite-add-missing-product-bgimage-columns.mjs",
    "db:seed": "npx tsx scripts/seed-brands.ts",
    "seed:travel-reviews": "npx tsx scripts/seed-travel-reviews.ts",
    "reviews:replace-csv": "npx tsx scripts/replace-travel-reviews-from-csv.ts",
    "reviews:replace-csv:apply": "npx tsx scripts/replace-travel-reviews-from-csv.ts --apply",
    "verify:travel-review-seed": "npx tsx scripts/verify-travel-review-seed.ts",
    "verify:public-leaks": "npx tsx scripts/verify-public-api-leak-guards.ts",
    "verify:prisma-runtime-policy": "npx tsx scripts/verify-prisma-runtime-policy.ts",
    "verify:rate-limit-store": "npx tsx scripts/verify-rate-limit-store.ts",
    "verify:departure-price-collect-ui": "npx tsx tools/verify-departure-price-collect-ui.ts",
    "verify:hotel-meal-display": "npx tsx scripts/verify-hotel-meal-display.ts",
    "verify:modetour-schedule-overlay": "npx tsx scripts/verify-modetour-schedule-overlay.ts",
    "verify:auth-split": "npx tsx scripts/verify-auth-split.ts",
    "verify:naver-unlink": "npx tsx tools/verify-naver-unlink-local.ts",
    "verify:manual-flight-hanatour": "npx tsx scripts/verify-manual-flight-hanatour.ts",
    "convert:gemini-png-webp": "node scripts/convert-gemini-png-to-webp.mjs",
    "verify:deploy-readiness": "node scripts/verify-deploy-readiness.mjs",
    "verify:register-detail-final-chain": "npx tsx scripts/verify-register-detail-final-chain.ts",
    "verify:register-admin-one-product": "npx tsx scripts/verify-register-admin-one-product.ts",
    "cleanup:register-admin": "npx tsx scripts/cleanup-register-admin-records.ts",
    "cleanup:register-admin:apply": "npx tsx scripts/cleanup-register-admin-records.ts --apply",
    "backfill:hero-seo-keywords": "npx tsx scripts/backfill-public-image-hero-seo-keywords.mts",
    "booking:purge-pii": "npx tsx scripts/purge-old-bookings.ts --dry-run --log-json",
    "booking:purge-pii:apply": "npx tsx scripts/purge-old-bookings.ts --apply --log-json",
    "booking:statuses:inspect": "npx tsx scripts/inspect-booking-statuses.ts",
    "booking:statuses:normalize:dry-run": "npx tsx scripts/normalize-booking-statuses.ts --dry-run",
    "booking:statuses:normalize:apply": "npx tsx scripts/normalize-booking-statuses.ts --apply",
    "products:purge-test:dry": "npx tsx scripts/purge-test-products.ts",
    "products:purge-test:markers": "npx tsx scripts/purge-test-products.ts --apply --mode markers",
    "gc:product-hero-storage:dry-run": "npx tsx scripts/gc-product-hero-storage.ts --dry-run",
    "gc:product-hero-storage:apply": "npx tsx scripts/gc-product-hero-storage.ts --apply --max-delete=20",
    "migrate:schedule-pexels:dry-run": "npx tsx scripts/rehost-schedule-pexels-batch.ts --dry-run",
    "migrate:schedule-pexels:apply": "npx tsx scripts/rehost-schedule-pexels-batch.ts --apply --limit=20",
    "cron:sync": "npx tsx scripts/sync-prices.ts",
    "cron:daemon": "npx tsx scripts/scheduler.ts",
    "calendar:daemon": "node -e \"require('child_process').spawn('python', ['-m', 'scripts.calendar_price_scheduler'], {stdio:'inherit', env:{...process.env, PYTHONPATH: process.cwd()}}).on('exit', process.exit)\"",
    "calendar:once": "node -e \"var r=require('child_process').spawnSync('python', ['-m', 'scripts.calendar_price_scheduler', '--once'], {stdio:'inherit', env:Object.assign({}, process.env, {PYTHONPATH: process.cwd()})}); process.exit(r.status||0)\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1036.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.100.1",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.3",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.36.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "pexels": "^1.4.0",
    "postcss": "^8.4.0",
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "sharp": "^0.33.5",
    "solapi": "^5.5.4",
    "tailwindcss": "^3.4.0",
    "transliteration": "^2.6.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
